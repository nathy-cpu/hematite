statement ok
CREATE TABLE `user data` (
  `id` INT PRIMARY KEY AUTO_INCREMENT,
  `active` BOOL NOT NULL DEFAULT TRUE,
  `score` FLOAT,
  `name` VARCHAR(32)
);

statement ok
INSERT INTO `user data` (`name`, `score`) VALUES ('alice', 2.5);

query TTT
SELECT `id`, `active`, `name`
FROM `user data`
ORDER BY `id`;
----
1 true alice

statement ok
ALTER TABLE `user data` ADD COLUMN nickname TEXT DEFAULT 'n/a';

statement ok
ALTER TABLE `user data` RENAME COLUMN nickname TO alias_name;

query TT
SELECT `name`, alias_name FROM `user data`;
----
alice n/a

