CREATE TABLE users (id INT PRIMARY KEY, name TEXT, active BOOLEAN);

statement ok
CREATE TABLE audit_log (id INT PRIMARY KEY, entry TEXT);

statement ok
CREATE VIEW active_users AS SELECT id, name FROM users WHERE active = TRUE;

statement ok
CREATE TRIGGER audit_users AFTER INSERT ON users AS INSERT INTO audit_log (id, entry) VALUES (NEW.id, NEW.name);

statement ok
INSERT INTO users (id, name, active) VALUES (1, 'Ada', TRUE);

query IT
SELECT id, name FROM active_users;
----
1 Ada

query T
SELECT entry FROM audit_log;
----
Ada

