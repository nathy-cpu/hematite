statement ok
CREATE TABLE orgs (id INTEGER PRIMARY KEY, active BOOLEAN, code TEXT UNIQUE);

statement ok
CREATE TABLE users (
  id INTEGER PRIMARY KEY,
  org_id INTEGER,
  email TEXT,
  score INTEGER,
  CONSTRAINT uq_users_email UNIQUE (email),
  CONSTRAINT chk_users_score CHECK (score >= 0),
  CONSTRAINT fk_users_org FOREIGN KEY (org_id) REFERENCES orgs (id) ON DELETE RESTRICT ON UPDATE RESTRICT
);

