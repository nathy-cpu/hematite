query I
SELECT user_id FROM (SELECT user_id FROM posts) AS p ORDER BY user_id LIMIT 1;
----
1

query I
WITH post_users AS (SELECT user_id FROM posts)
SELECT post_users.user_id FROM post_users ORDER BY post_users.user_id DESC LIMIT 1;
----
3

query I
SELECT u.id
FROM users AS u
WHERE EXISTS (SELECT p.user_id FROM posts AS p WHERE p.user_id = u.id)
ORDER BY u.id;
----
1
3

query II
SELECT u.id, (SELECT COUNT(*) FROM posts AS p WHERE p.user_id = u.id)
FROM users AS u
ORDER BY u.id;
----
1 2
2 0
3 1

query I rowsort
SELECT id FROM users
UNION ALL
SELECT user_id FROM posts;
----
1
1
1
2
3
3

query I
SELECT id FROM users
INTERSECT
SELECT user_id FROM posts
ORDER BY id;
----
1
3

query I
SELECT id FROM users
EXCEPT
SELECT user_id FROM posts
ORDER BY id;
----
2

query I
WITH RECURSIVE nums AS (
  SELECT n FROM seeds
  UNION ALL
  SELECT n + 1 AS n FROM nums WHERE n < 3
)
SELECT n FROM nums ORDER BY n;
----
1
2
3
