statement ok
CREATE TABLE teams (id INTEGER PRIMARY KEY, name TEXT);

statement ok
CREATE TABLE players (id INTEGER PRIMARY KEY, team_id INTEGER, name TEXT, score INTEGER);

statement ok
INSERT INTO teams (id, name) VALUES (1, 'A'), (2, 'B');

statement ok
INSERT INTO players (id, team_id, name, score) VALUES
  (1, 1, 'alice', 10),
  (2, 1, 'amy', 8),
  (3, 2, 'bob', 7);

query TTI
SELECT t.name, p.name, p.score
FROM teams t
JOIN players p ON t.id = p.team_id
ORDER BY t.name, p.score DESC;
----
A alice 10
A amy 8
B bob 7

query TI
SELECT t.name, COUNT(*)
FROM teams t
LEFT JOIN players p ON t.id = p.team_id
GROUP BY t.name
ORDER BY t.name;
----
A 2
B 1

query TI
SELECT team_id, SUM(score)
FROM players
GROUP BY team_id
HAVING SUM(score) >= 10
ORDER BY team_id;
----
1 18
