statement ok
CREATE TABLE a (i INTEGER PRIMARY KEY);

statement ok
INSERT INTO a (i) VALUES (42);

statement error
SELECT j : 42;

statement error
SELECT "j" : 42;

statement error
SELECT j : i FROM a;

statement error
SELECT * FROM b : a;

statement error
SELECT a : 42 AS b;

statement error
FROM r : a;

statement ok
DROP TABLE a;
