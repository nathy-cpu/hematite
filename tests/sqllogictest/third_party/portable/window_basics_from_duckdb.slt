# Adapted from:
# https://github.com/duckdb/duckdb/blob/main/test/sql/window/test_basic_window.test

statement ok
CREATE TABLE basic_window_test (
  depname TEXT,
  empno INT PRIMARY KEY,
  salary INT
);

statement ok
INSERT INTO basic_window_test (depname, empno, salary) VALUES
  ('develop', 10, 5200),
  ('sales', 1, 5000),
  ('personnel', 5, 3500),
  ('sales', 4, 4800),
  ('personnel', 2, 3900),
  ('develop', 7, 4200),
  ('develop', 9, 4500),
  ('sales', 3, 4800),
  ('develop', 8, 6000),
  ('develop', 11, 5200);

query IIII nosort
SELECT depname, empno, salary, SUM(salary) OVER (PARTITION BY depname)
FROM basic_window_test
ORDER BY depname, empno;
----
develop 7 4200 25100
develop 8 6000 25100
develop 9 4500 25100
develop 10 5200 25100
develop 11 5200 25100
personnel 2 3900 7400
personnel 5 3500 7400
sales 1 5000 14600
sales 3 4800 14600
sales 4 4800 14600

query I nosort
SELECT ROW_NUMBER() OVER (PARTITION BY depname ORDER BY salary)
FROM basic_window_test
ORDER BY depname, salary;
----
1
2
3
4
5
1
2
1
2
