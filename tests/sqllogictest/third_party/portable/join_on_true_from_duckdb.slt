# Adapted from:
# https://github.com/duckdb/duckdb/blob/main/test/sql/join/test_join_always_true_conditions.test
# https://github.com/duckdb/duckdb/blob/main/test/sql/join/left_outer/test_left_join_on_true.test

statement ok
CREATE TABLE join_true_left (id INTEGER PRIMARY KEY, val INTEGER);

statement ok
INSERT INTO join_true_left (id, val) VALUES (1, 10), (2, 20);

statement ok
CREATE TABLE join_true_right (id INTEGER PRIMARY KEY, category INTEGER);

statement ok
INSERT INTO join_true_right (id, category) VALUES (1, 100), (2, 200);

query IIII rowsort
SELECT * FROM join_true_left l
INNER JOIN join_true_right r ON 1 = 1;
----
1 10 1 100
1 10 2 200
2 20 1 100
2 20 2 200

query IIII rowsort
SELECT * FROM join_true_left l
LEFT JOIN join_true_right r ON 1 = 1;
----
1 10 1 100
1 10 2 200
2 20 1 100
2 20 2 200

query IIII nosort
SELECT * FROM join_true_left
LEFT OUTER JOIN join_true_right ON 1 = 1 AND join_true_left.id = join_true_right.id AND 1 = 1
ORDER BY join_true_left.id;
----
1 10 1 100
2 20 2 200

query IIII nosort
SELECT * FROM join_true_left
LEFT OUTER JOIN join_true_right ON 1 = 1 AND join_true_left.id = join_true_right.id AND 1 = 0
ORDER BY join_true_left.id;
----
1 10 NULL NULL
2 20 NULL NULL
