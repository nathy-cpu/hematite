# Adapted from:
# https://github.com/duckdb/duckdb/blob/main/test/sql/setops/test_nested_except.test
# https://github.com/duckdb/duckdb/blob/main/test/sql/setops/test_union_except_empty.test

statement ok
CREATE TABLE setops_union_test (i INT PRIMARY KEY);

statement ok
INSERT INTO setops_union_test (i) VALUES (1), (2), (3), (4);

query I nosort
SELECT i FROM setops_union_test
UNION
SELECT 1 FROM setops_union_test WHERE 1 = 0
ORDER BY i;
----
1
2
3
4

query I nosort
SELECT i FROM setops_union_test
EXCEPT
SELECT 1 FROM setops_union_test WHERE 1 = 0
ORDER BY i;
----
1
2
3
4

statement ok
CREATE TABLE setops_a (i INT PRIMARY KEY);

statement ok
CREATE TABLE setops_b (i INT PRIMARY KEY);

statement ok
CREATE TABLE setops_c (i INT PRIMARY KEY);

statement ok
INSERT INTO setops_a (i) VALUES (42), (43), (44);

statement ok
INSERT INTO setops_b (i) VALUES (43);

statement ok
INSERT INTO setops_c (i) VALUES (44);

query I nosort
SELECT * FROM (
  SELECT * FROM setops_a
  EXCEPT
  SELECT * FROM setops_b
) left_except
EXCEPT
SELECT * FROM setops_c;
----
42
