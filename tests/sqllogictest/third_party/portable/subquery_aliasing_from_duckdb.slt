CREATE TABLE subquery_alias_test (i INTEGER PRIMARY KEY);

statement ok
INSERT INTO subquery_alias_test (i) VALUES (42);

query I nosort
SELECT * FROM (SELECT i AS j FROM subquery_alias_test GROUP BY i) sq1 WHERE j = 42;
