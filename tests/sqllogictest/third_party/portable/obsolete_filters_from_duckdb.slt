statement ok
CREATE TABLE integers(a INT PRIMARY KEY, b INT);

statement ok
INSERT INTO integers (a, b) VALUES (1, 10), (2, 12), (3, 14), (4, 16), (5, NULL);

query II rowsort
SELECT a, b FROM integers WHERE 1 = 1;
----
1 10
2 12
3 14
4 16
5 NULL

query II
SELECT a, b FROM integers WHERE 1 = 0;
----

query II
SELECT a, b FROM integers WHERE NULL = NULL;
----

query II
SELECT a, b FROM integers WHERE a = 2 AND a = 2;
----
2 12

query II
SELECT a, b FROM integers WHERE a = 2 AND a > 0;
----
2 12

query II
SELECT a, b FROM integers WHERE a = 2 AND a < 4;
----
2 12

query II
SELECT a, b FROM integers WHERE a > 2 AND a > 4;
----
5 NULL

query II
SELECT a, b FROM integers WHERE a < 2 AND a < 4;
----
1 10

query II
SELECT a, b FROM integers WHERE a < 2 AND a != 3;
----
1 10

query II
SELECT a, b FROM integers WHERE a >= 4 AND a != 4 AND a != 4;
----
5 NULL

query II
SELECT a, b FROM integers WHERE a < 3 AND a < 4 AND a < 5 AND a < 10 AND a < 2 AND a < 20;
----
1 10

query II
SELECT a, b FROM integers WHERE a = 2 AND a = 4;
----

query II
SELECT a, b FROM integers WHERE a = 2 AND a > 4;
----

query II
SELECT a, b FROM integers WHERE a = 2 AND a > 2;
----

query II
SELECT a, b FROM integers WHERE a = 4 AND a < 2;
----

query II
SELECT a, b FROM integers WHERE a = 2 AND a != 2;
----

query II
SELECT a, b FROM integers WHERE 1 = 0;
----

query II
SELECT a, b FROM integers WHERE a < 2 AND 1 = 0;
----

statement ok
DROP TABLE integers;
