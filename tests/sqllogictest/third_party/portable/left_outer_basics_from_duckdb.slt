# Adapted from:
# https://github.com/duckdb/duckdb/blob/main/test/sql/join/left_outer/test_left_outer.test

statement ok
CREATE TABLE left_join_test (i INT PRIMARY KEY, j INT);

statement ok
INSERT INTO left_join_test (i, j) VALUES (1, 2), (2, 3), (3, 4);

statement ok
CREATE TABLE left_join_test2 (k INT PRIMARY KEY, l INT);

statement ok
INSERT INTO left_join_test2 (k, l) VALUES (1, 10), (2, 20);

query IIII nosort
SELECT * FROM left_join_test
LEFT OUTER JOIN left_join_test2 ON left_join_test.i = left_join_test2.k
ORDER BY i;
----
1 2 1 10
2 3 2 20
3 4 NULL NULL

query IIII nosort
SELECT * FROM left_join_test
LEFT OUTER JOIN left_join_test2 ON left_join_test.i = left_join_test2.k
WHERE k IS NOT NULL
ORDER BY i;
----
1 2 1 10
2 3 2 20

query IIII nosort
SELECT * FROM left_join_test
LEFT OUTER JOIN left_join_test2 ON 1 = 2
ORDER BY i;
----
1 2 NULL NULL
2 3 NULL NULL
3 4 NULL NULL

query IIII nosort
SELECT * FROM left_join_test
LEFT OUTER JOIN left_join_test2 ON 1 = 1
ORDER BY i, k;
----
1 2 1 10
1 2 2 20
2 3 1 10
2 3 2 20
3 4 1 10
3 4 2 20

query IIII nosort
SELECT * FROM left_join_test
LEFT OUTER JOIN left_join_test2 ON left_join_test.i < left_join_test2.k
WHERE left_join_test.i <= 2
ORDER BY i;
----
1 2 2 20
2 3 NULL NULL
