# Adapted from:
# https://github.com/duckdb/duckdb/blob/main/test/sql/setops/test_setops.test
# https://github.com/duckdb/duckdb/blob/main/test/sql/setops/test_except.test

statement ok
CREATE TABLE setops_test (a INT PRIMARY KEY, b INT);

statement ok
INSERT INTO setops_test (a, b) VALUES (11, 1), (12, 1), (13, 2);

query I nosort
SELECT b FROM setops_test WHERE a = 11 UNION ALL SELECT b FROM setops_test WHERE a = 13;
----
1
2

query IT rowsort
SELECT a, 'x' FROM setops_test WHERE a < 13 UNION SELECT a, 'x' FROM setops_test WHERE a >= 12;
----
11 x
12 x
13 x

query I rowsort
SELECT b FROM setops_test WHERE a < 13 UNION SELECT b FROM setops_test WHERE a > 11;
----
1
2

statement ok
CREATE TABLE except_a (i INT PRIMARY KEY);

statement ok
INSERT INTO except_a (i) VALUES (41), (42), (43);

statement ok
CREATE TABLE except_b (i INT PRIMARY KEY);

statement ok
INSERT INTO except_b (i) VALUES (40), (43), (44);

query I rowsort
SELECT * FROM except_a EXCEPT SELECT * FROM except_b;
----
41
42

query I nosort
SELECT * FROM except_a INTERSECT SELECT * FROM except_b;
----
43
