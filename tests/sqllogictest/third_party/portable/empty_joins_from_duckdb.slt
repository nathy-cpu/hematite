statement ok
CREATE VIEW integers_empty AS SELECT * FROM integers WHERE 1=0;

statement ok
CREATE VIEW integers2_empty AS SELECT * FROM integers2 WHERE 1=0;

statement ok
CREATE VIEW empty_join AS SELECT * FROM integers JOIN integers2_empty ON integers.i = integers2_empty.i;

# empty LHS
query I
SELECT COUNT(*) FROM integers_empty JOIN integers2 ON integers_empty.i = integers2.i;
----
0

query I
SELECT COUNT(*) FROM integers_empty JOIN integers2 ON (integers_empty.i>integers2.i);
----
0

query I
SELECT COUNT(*) FROM integers_empty JOIN integers2 ON (integers_empty.i<>integers2.i);
----
0

query I
SELECT COUNT(*) FROM integers_empty JOIN integers2 ON (integers_empty.i<>integers2.i OR integers_empty.i+1<>integers2.i);
----
0

query I
SELECT * FROM integers_empty JOIN integers2 ON integers_empty.i = integers2.i;
----

query I
SELECT COUNT(*) FROM integers_empty LEFT JOIN integers2 ON integers_empty.i = integers2.i;
----
0

