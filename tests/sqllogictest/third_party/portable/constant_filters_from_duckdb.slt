# Adapted from:
# https://github.com/duckdb/duckdb/blob/main/test/sql/filter/test_constant_comparisons.test

statement ok
CREATE TABLE integers(a INTEGER PRIMARY KEY, b INTEGER);

statement ok
INSERT INTO integers (a, b) VALUES (2, 12);

query II
SELECT * FROM integers WHERE 2 = 2;
----
2 12

statement ok
SELECT * FROM integers WHERE 2 = 3;

query II
SELECT * FROM integers WHERE 2 != 3;
----
2 12

statement ok
SELECT * FROM integers WHERE 2 != 2;

query II
SELECT * FROM integers WHERE 2 > 1;
----
2 12

statement ok
SELECT * FROM integers WHERE 2 > 2;

query II
SELECT * FROM integers WHERE 2 >= 2;
----
2 12

statement ok
SELECT * FROM integers WHERE 2 >= 3;

query II
SELECT * FROM integers WHERE 2 < 3;
----
2 12

statement ok
SELECT * FROM integers WHERE 2 < 2;

query II
SELECT * FROM integers WHERE 2 <= 2;
----
2 12

statement ok
SELECT * FROM integers WHERE 2 <= 1;

query T
SELECT a = NULL FROM integers;
----
NULL

query T
SELECT NULL = a FROM integers;
----
NULL

query II
SELECT * FROM integers WHERE 2 IN (2, 3, 4, 5);
----
2 12

statement ok
SELECT * FROM integers WHERE 2 NOT IN (2, 3, 4, 5);

query II
SELECT * FROM integers WHERE 2 IN (((1 * 2) + (1 * 0)) * 1, 3, 4, 5);
----
2 12

statement ok
SELECT * FROM integers WHERE 2 IN ((1 + 1) * 2, 3, 4, 5);

query I
SELECT CASE WHEN true THEN 13 ELSE 12 END FROM integers;
----
13

statement ok
DROP TABLE integers;
