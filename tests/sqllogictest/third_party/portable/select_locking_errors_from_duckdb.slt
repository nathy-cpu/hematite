# Adapted from:
# https://github.com/duckdb/duckdb/blob/main/test/sql/select/test_select_locking.test

statement ok
CREATE TABLE t (id INT PRIMARY KEY, value TEXT);

statement error
SELECT * FROM t FOR UPDATE;

statement error
SELECT * FROM t FOR NO KEY UPDATE;

statement error
SELECT * FROM t FOR SHARE;

statement error
SELECT * FROM t KEY SHARE;

statement ok
DROP TABLE t;
