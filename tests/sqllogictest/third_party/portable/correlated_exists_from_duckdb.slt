# Adapted from:
# https://github.com/duckdb/duckdb/blob/main/test/sql/subquery/exists/test_correlated_exists.test

statement ok
CREATE TABLE correlated_exists_test (i INT PRIMARY KEY);

statement ok
INSERT INTO correlated_exists_test (i) VALUES (1), (2), (3);

query I nosort
SELECT i
FROM correlated_exists_test outer_test
WHERE EXISTS(SELECT i FROM correlated_exists_test WHERE i = outer_test.i)
ORDER BY i;
----
1
2
3

query I nosort
SELECT i
FROM correlated_exists_test outer_test
WHERE EXISTS(SELECT i FROM correlated_exists_test WHERE outer_test.i > 2)
ORDER BY i;
----
3

query I nosort
SELECT COUNT(*)
FROM correlated_exists_test outer_test
WHERE EXISTS(SELECT i FROM correlated_exists_test WHERE i = outer_test.i);
----
3
