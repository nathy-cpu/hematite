# Adapted from:
# https://github.com/duckdb/duckdb/blob/main/test/sql/subquery/table/test_table_subquery.test

statement ok
CREATE TABLE subquery_test (i INTEGER PRIMARY KEY, j INTEGER);

statement ok
INSERT INTO subquery_test (i, j) VALUES (3, 4), (4, 5), (5, 6);

query II rowsort
SELECT * FROM (SELECT i, j AS d FROM subquery_test ORDER BY i) AS b;
----
3 4
4 5
5 6

query I rowsort
SELECT b.d FROM (SELECT i * 2 + j AS d FROM subquery_test) AS b;
----
10
13
16

query IIII rowsort
SELECT a.i, a.j, b.r, b.j
FROM (SELECT i, j FROM subquery_test) AS a
INNER JOIN (SELECT i + 1 AS r, j FROM subquery_test) AS b
ON a.i = b.r;
----
4 5 4 4
5 6 5 5
