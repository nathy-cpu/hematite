# Adapted from:
# https://github.com/risinglightdb/sqllogictest-rs/blob/main/tests/slt/error_sqlstate.slt

statement error
SELECT * FROM non_existent_table;

query error
SELECT * FROM missing_table;

statement ok
CREATE TABLE error_demo(id INT PRIMARY KEY, value INT);

statement ok
INSERT INTO error_demo (id, value) VALUES (1, 10);

statement error
SELECT missing_column FROM error_demo;

query error
SELECT missing_column FROM error_demo;

statement error
SELEKT * FROM error_demo;

query error
SELECT * FORM error_demo;

statement error
INSERT INTO error_demo (id, value) VALUES (1, 20);

query error
INSERT INTO error_demo (id, value) VALUES (1, 30);

statement ok
DROP TABLE error_demo;
