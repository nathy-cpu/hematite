# Adapted from:
# https://github.com/duckdb/duckdb/blob/main/test/sql/order/test_limit.test
# https://github.com/duckdb/duckdb/blob/main/test/sql/limit/test_preserve_insertion_order.test

statement ok
CREATE TABLE limit_test (a INTEGER PRIMARY KEY, b INTEGER);

statement ok
INSERT INTO limit_test (a, b) VALUES (11, 22), (12, 21), (13, 22), (14, 23), (15, 24);

query I nosort
SELECT a FROM limit_test ORDER BY a LIMIT 1;
----
11

query I nosort
SELECT a FROM limit_test ORDER BY a LIMIT 2 OFFSET 1;
----
12
13

query I nosort
SELECT a FROM limit_test ORDER BY a OFFSET 3;
----
14
15

statement error
SELECT a FROM limit_test LIMIT a;

statement error
SELECT a FROM limit_test LIMIT a + 1;
