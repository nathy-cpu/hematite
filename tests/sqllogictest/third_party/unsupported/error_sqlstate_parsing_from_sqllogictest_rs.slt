# Upstream reference:
# https://github.com/risinglightdb/sqllogictest-rs/blob/main/tests/slt/error_sqlstate_parsing.slt
#
# This file is intentionally skipped by the Hematite sqllogictest runner because
# it exercises SQLSTATE-aware error-pattern parsing in the harness rather than
# portable SQL behavior in the database engine itself.

statement error (42P01)
SELECT invalid_syntax FROM non_existent_table

statement error (42703)
SELECT non_existent_column FROM missing_table

statement error (42601)
SELECT * FORM missing_table
