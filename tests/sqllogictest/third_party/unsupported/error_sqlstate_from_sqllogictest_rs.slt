# Upstream reference:
# https://github.com/risinglightdb/sqllogictest-rs/blob/main/tests/slt/error_sqlstate.slt
#
# This file is intentionally skipped by the Hematite sqllogictest runner because
# it depends on SQLSTATE-aware error matching that Hematite does not expose.

statement error (42P01)
SELECT * FROM non_existent_table

query error (42P01)
SELECT * FROM missing_table

statement error (42703)
SELECT non_existent_column FROM some_table

query error (42703)
SELECT missing_column FROM another_table

statement error (42601)
SELECT * FORM some_table

query error (42601)
SELEKT * FROM some_table
