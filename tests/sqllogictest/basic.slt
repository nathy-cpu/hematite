CREATE VIEW adult_names AS SELECT name FROM users WHERE age >= 30;

query T
SELECT name FROM adult_names;
----
Ada

statement ok
CREATE TABLE audit_log (id INTEGER PRIMARY KEY, entry TEXT);

statement ok
CREATE TRIGGER audit_users AFTER INSERT ON users AS INSERT INTO audit_log (id, entry) VALUES (NEW.id, NEW.name);

statement ok
INSERT INTO users (id, name, age) VALUES (4, 'Diya', 41);

query T
SELECT entry FROM audit_log;
----
Diya

